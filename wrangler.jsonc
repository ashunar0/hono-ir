{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hono-ir",
  "compatibility_date": "2026-04-28",
  "main": "./src/server.ts",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hono-ir",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "drizzle",
    },
  ],
}
